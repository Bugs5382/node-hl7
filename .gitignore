# Whitelist-style .gitignore.
# Everything at the repo root is ignored by default; only the entries
# explicitly re-included below are tracked. Inside the re-included
# directories, the always-ignored patterns at the bottom still apply.

# Ignore everything at the top level.
/*

# Re-include tracked top-level entries.
!/.github/
!/.gitignore
!/.husky/
!/.npmpackagejsonlintrc.json
!/Dockerfile
!/LICENSE
!/README.md
!/__tests__/
!/docker/
!/eslint.config.base.mjs
!/package.json
!/packages/
!/pages/
!/scripts/
!/tsconfig.base.json
!/tsconfig.json
!/vitest.config.base.mts
!/vitest.config.ts
!/vitest.workspace.ts

# Always-ignored artifacts, anywhere in the tree.
node_modules/
lib/
dist/
coverage/
.nyc_output/
temp/
package-lock.json
*.log
*.tgz
.DS_Store

# Track the shared governance (hooks + settings); other .claude stays local.
!/.claude/
/.claude/*
!/.claude/hooks/
!/.claude/settings.json

# Track shared governance file.
!/CLAUDE.md
