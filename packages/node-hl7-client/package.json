{
  "name": "node-hl7-client",
  "version": "3.1.0",
  "description": "A pure Node.js HL7 Client that allows for communication to a HL7 Broker/Server that can send properly formatted HL7 messages with ease.It can also parse and then you can extract message segments out.",
  "keywords": [
    "hl7",
    "hl7-parser",
    "hl7-client",
    "hl7-builder",
    "hl7-specifications",
    "hl7-validation"
  ],
  "homepage": "https://github.com/Bugs5382/node-hl7#readme",
  "bugs": {
    "url": "https://github.com/Bugs5382/node-hl7/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bugs5382/node-hl7.git"
  },
  "license": "MIT",
  "author": "Shane Froebel",
  "exports": {
    ".": {
      "types": "./lib/types/index.d.ts",
      "import": "./lib/esm/index.mjs",
      "require": "./lib/cjs/index.js",
      "default": "./lib/cjs/index.js"
    },
    "./hl7": {
      "types": "./lib/types/hl7.d.ts",
      "import": "./lib/esm/hl7.mjs",
      "require": "./lib/cjs/hl7.js",
      "default": "./lib/cjs/hl7.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*",
      "default": "./src/*"
    }
  },
  "main": "./lib/cjs/index.js",
  "module": "./lib/esm/index.mjs",
  "types": "./lib/types/index.d.ts",
  "typesVersions": {
    "*": {
      "hl7": [
        "lib/types/hl7"
      ]
    }
  },
  "files": [
    "lib/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "build:dev": "NODE_ENV=development tsdown",
    "clean": "rm -rf coverage docs lib temp",
    "lint": "npm run lint:npm && eslint | snazzy",
    "lint:fix": "npm run lint:npm && eslint --fix | snazzy",
    "lint:package": "npx sort-package-json",
    "npm:lint": "npmPkgJsonLint .",
    "pack": "npm pack",
    "prepublishOnly": "npm run clean && npm run build && npm run pack",
    "typedoc": "typedoc",
    "typedoc:watch": "typedoc -watch",
    "update": "npx npm-check-updates -u --enginesNode && npm run update:post-update",
    "update:post-update": "rm -f package-lock.json && rm -rf node_modules && npm install && npm run test"
  },
  "devDependencies": {
    "@redis/client": "^5.12.1",
    "node-hl7-server": "^3.3.0",
    "redis-memory-server": "^0.16.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
