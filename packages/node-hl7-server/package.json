{
  "name": "node-hl7-server",
  "version": "4.0.0",
  "description": "Node.js client library for creating a HL7 Server which can accept incoming a properly formatted HL7 message(s), and then parses the HL7 message. Once the message has been parsed you can then do something with the final result that you so desire.",
  "keywords": [
    "hl7",
    "hl7-parser",
    "hl7-client",
    "hl7-server",
    "hl7-builder",
    "hl7-specification",
    "hl7-validation"
  ],
  "homepage": "https://github.com/Bugs5382/node-hl7#readme",
  "bugs": {
    "url": "https://github.com/Bugs5382/node-hl7/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bugs5382/node-hl7.git"
  },
  "license": "MIT",
  "author": "Shane A. Froebel",
  "exports": {
    ".": {
      "types": "./lib/types/index.d.mts",
      "import": "./lib/esm/index.mjs",
      "require": "./lib/cjs/index.cjs",
      "default": "./lib/cjs/index.cjs"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*",
      "default": "./src/*"
    }
  },
  "main": "./lib/cjs/index.cjs",
  "module": "./lib/esm/index.mjs",
  "types": "./lib/types/index.d.mts",
  "files": [
    "lib/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "build:dev": "NODE_ENV=development tsdown",
    "clean": "rm -rf coverage docs lib temp",
    "docker:build": "../../docker build -t docker-node-hl7-server:latest .",
    "lint:npm": "npmPkgJsonLint .",
    "lint:package": "npx sort-package-json",
    "pack": "npm pack",
    "prepublishOnly": "npm run clean && npm run build",
    "typedoc": "typedoc",
    "typedoc:watch": "typedoc -watch",
    "update": "npx npm-check-updates -u --enginesNode && npm run update:post-update",
    "update:post-update": "npm install && npm run test"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "peerDependencies": {
    "node-hl7-client": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "node-hl7-client": "*"
  }
}
