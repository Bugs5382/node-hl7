{
  "name": "node-hl7",
  "private": true,
  "description": "HL7 monorepo — node-hl7-client and node-hl7-server",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "clean": "find packages -name 'node_modules' -maxdepth 2 -type d -exec rm -rf {} + 2>/dev/null; find packages -name 'lib' -maxdepth 2 -type d -exec rm -rf {} + 2>/dev/null; find packages -name 'dist' -maxdepth 2 -type d -exec rm -rf {} + 2>/dev/null; find packages -name 'coverage' -maxdepth 2 -type d -exec rm -rf {} + 2>/dev/null; true",
    "format:check": "npm run format:check --workspaces --if-present",
    "format:write": "npm run format:write --workspaces --if-present",
    "format:check:local": "prettier --check 'pages/**/*.md' '__tests__/**/*.ts'",
    "format:write:local": "prettier --write 'pages/**/*.md' '__tests__/**/*.ts'",
    "lint": "npm run lint --workspaces --if-present",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:verbose": "vitest run --reporter verbose",
    "test:watch": "vitest watch",
    "typedoc": "npm run typedoc --workspaces --if-present",
    "update": "npm run update --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@shipgirl/typedoc-plugin-versions": "^0.3.2",
    "@types/node": "^25.6.0",
    "@types/tcp-port-used": "^1.0.4",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sort-class-members": "^1.22.1",
    "globals": "^17.5.0",
    "npm-check-updates": "^20.0.2",
    "npm-package-json-lint": "^9.1.0",
    "npm-package-json-lint-config-default": "^8.0.1",
    "portfinder": "^1.0.38",
    "pre-commit": "^1.2.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "snazzy": "^9.0.0",
    "sort-package-json": "^3.6.1",
    "tcp-port-used": "^1.0.2",
    "tsdown": "^0.21.10",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "precommit": [
    "lint"
  ]
}
