# Ignore everything
*

# But not these files...
!*.ts
!*.tsx
!*.js
!*.mts
!*.mjs
!*.cjs
!.github/**/*.yaml

# ...even if they are in subdirectories
!*/

# Always-ignored folders (root and any nested copies inside workspaces)
/node_modules/**
**/node_modules/**
/lib/**
**/lib/**
/dist/**
**/dist/**
/coverage/**
**/coverage/**
/temp/**
**/temp/**
/docs/**
**/docs/**
/.idea/**
/.husky/**